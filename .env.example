# Copy this file to .env and fill in only the keys you want to use.
# Never commit .env to version control. Add it to .gitignore (already done).
#
# The proprietary brain in brain.py runs end to end with NO API key set.
# These keys only enable the optional CrewAI plus LLM path that activates
# under "python main.py --mode demo".

# Pick one. Any one is enough.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# Optional, controls the Human in the Lead feedback layer.
# Set to "off" to force static reproducibility mode (no adaptive corrections).
# Default is on (adaptive mode active).
WORKFORCE_BRAIN_LEARNING=on
